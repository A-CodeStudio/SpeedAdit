          <p style="margin-top:18px;">support@desktopapp.com</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      © 2026 DesktopApp. Все права защищены.
    </div>
  </footer>
</body>
</html>
