          <div style="margin-top:18px; padding:16px; border-radius:20px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); color:var(--muted); line-height:1.7;">
            <strong style="display:block; color:var(--text); margin-bottom:8px;">Проверка файла</strong>
            SHA256: 9f3c-example-hash-change-me
